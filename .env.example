# ━━━━━━━━━━━━━━━━━━━ Telegram Bot (Обязательные) ━━━━━━━━━━━━━━━━━━━
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
BOT_USERNAME=your_bot_username
REFERRAL_BOT_USERNAME=your_bot_username
OWNER_ID=YOUR_TELEGRAM_ID

# ━━━━━━━━━━━━━━━━━━━ База данных ━━━━━━━━━━━━━━━━━━━
# Локально: clicktohn.db
# На Railway Volume: /data/clicktohn.db
DB_NAME=clicktohn.db

# ━━━━━━━━━━━━━━━━━━━ Сбербанк (для платежей) ━━━━━━━━━━━━━━━━━━━
SBER_CARD=2202 2081 2341 5326 (Имя Фамилия)

# ━━━━━━━━━━━━━━━━━━━ Railway Deploy ━━━━━━━━━━━━━━━━━━━
# PORT будет автоматически назначена Railway (обычно 8080)
PORT=8080
RAILWAY_ENVIRONMENT=production
